# Supabase Edge Functions Environment Variables Example
# Set these secrets in your Supabase project using the Supabase CLI:
# supabase secrets set GEMINI_API_KEY=your_gemini_api_key CAT_API_KEY=your_cat_api_key

# Gemini API Key (Required for AI health report & photo analysis)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model Selection (Optional, defaults to gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# The Cat API Key (Required for the Cat Matchmaker quiz loading gifs and search)
CAT_API_KEY=your_cat_api_key_here
