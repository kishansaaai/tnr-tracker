# TNR Tracker Environment Variables
# Copy this file to .env and fill in your values

# Supabase
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# AI — Groq (Primary)
VITE_GROQ_API_KEY=your-groq-api-key
VITE_GROQ_MODEL=llama-3.3-70b-versatile

# AI — Gemini (Fallback)
VITE_GEMINI_API_KEY=your-gemini-api-key
VITE_GEMINI_MODEL=gemini-1.5-flash-latest

# The Cat API
VITE_CAT_API_KEY=your-thecatapi-key

# Edge Functions / Server-Side APIs (securely stored in Supabase Edge Functions, do NOT prefix with VITE_)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
CAT_API_KEY=your-thecatapi-key
