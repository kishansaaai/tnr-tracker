# TNR Tracker Environment Variables
# Copy this file to .env and fill in your values

# Supabase
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# The Cat API (Client Proxy Fallback)
VITE_CAT_API_KEY=your-thecatapi-key

# Edge Functions / Server-Side APIs (securely stored in Supabase Edge Secrets, do NOT prefix with VITE_)
# Set these using `supabase secrets set GEMINI_API_KEY=your-key`
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
CAT_API_KEY=your-thecatapi-key

